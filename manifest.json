{
    "manifest_version": 3,
    "version": "0.4",
    "name": "AutumnFox New Tab",
    "description": "A customizable 'New Tab' page",
    "icons": {
        "512": "/assets/AutumnFox.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "autumnfoxnewtab@kingiwrs.com",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "permissions": [
        "storage"
    ],
    "chrome_url_overrides": {
        "newtab": "/newtab/newtab.html"
    },
    "chrome_settings_overrides": {
        "homepage": "/newtab/newtab.html"
    },
    "action": {
        "default_popup": "/popup/popup.html",
        "default_icon": "/assets/AutumnFox.png"
    }
}
